# ─────────────────────────────────────────────────────────────
# OBLIGATORIO — API key de Google AI Studio (Gemini)
# Obtén una gratis en: https://aistudio.google.com/app/apikey
# ─────────────────────────────────────────────────────────────
GOOGLE_API_KEY=''

# ─────────────────────────────────────────────────────────────
# RUTAS DE DATOS (con defaults funcionales para ejecución local)
# ─────────────────────────────────────────────────────────────

# Directorio donde se almacena el JSONL generado por el crawler
DATA_DIR=''

# Directorio donde se persiste la base vectorial ChromaDB
DB_PATH=''

# ─────────────────────────────────────────────────────────────
# MODELO Y BASE VECTORIAL
# ─────────────────────────────────────────────────────────────

# Modelo de embeddings de HuggingFace (multilingüe, 384 dims, gratuito)
# Default: sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
EMBEDDINGS_MODEL=''

# Nombre de la colección en ChromaDB
# Default: bancolombia_docs
CHROMA_COLLECTION=''

# Modelo LLM a utilizar (formato: proveedor:modelo)
# Default: google_genai:gemini-3.1-flash-lite-preview
LLM_MODEL=''

# ─────────────────────────────────────────────────────────────
# SERVIDOR MCP
# ─────────────────────────────────────────────────────────────

# Nombre del servidor MCP (visible en logs y clientes MCP)
# Default: BancolombiaKnowledgeServer
MCP_SERVER_NAME=''

# Número de documentos a recuperar por búsqueda semántica (top-k)
# Default: 3
SEARCH_K_VALUE=''

# ─────────────────────────────────────────────────────────────
# PIPELINE DE INDEXACIÓN
# ─────────────────────────────────────────────────────────────

# Tamaño del lote para indexación en ChromaDB
# Default: 50
INDEX_BATCH_SIZE=''

# Tamaño del chunk en caracteres para el text splitter
# Default: 1500
INDEX_CHUNK_SIZE=''

# Overlap entre chunks consecutivos en caracteres
# Default: 300
INDEX_CHUNK_OVERLAP=''

# ─────────────────────────────────────────────────────────────
# AGENTE CONVERSACIONAL
# ─────────────────────────────────────────────────────────────

# Umbral de tokens del historial para activar la summarización
# Default: 3000
HISTORY_THRESHOLD=''

# Número de mensajes recientes a conservar tras la summarización
# Default: 10
HISTORY_KEEP=''

# ─────────────────────────────────────────────────────────────
# CRAWLER
# ─────────────────────────────────────────────────────────────

# URL semilla del crawler
# Default: https://www.bancolombia.com/personas
CRAWLER_SEED_URL=''

# Patrones de URL a omitir (separados por comas)
# Default: /!ut/p/,.pdf,contenthandler,solicitud-turno.apps.,segurodeviaje.
CRAWLER_SKIP_PATTERNS=''

# Umbral de uso de memoria (%) para pausar el crawler
# Default: 80.0
CRAWLER_MEMORY_THRESHOLD=''

# Máximo de sesiones concurrentes del crawler
# Default: 5
CRAWLER_MAX_SESSIONS=''

# Delay mínimo entre requests en segundos
# Default: 2.0
CRAWLER_MIN_DELAY=''

# Delay máximo entre requests en segundos
# Default: 4.0
CRAWLER_MAX_DELAY=''
